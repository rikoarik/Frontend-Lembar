# Public, browser-visible env values only.
# Backend/secret env values are out of scope for F0-02.
#
# Prefix rules:
#   NEXT_PUBLIC_* -> inlined into the browser bundle. Never put secrets here.
#   unprefixed    -> server runtime only.
#
# Required at runtime (safe defaults are baked into src/lib/runtime/env.ts):
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=/v1
NEXT_PUBLIC_API_MODE=mock
NEXT_PUBLIC_ANALYTICS_ENABLED=false
